const API_BASE_URL = "http://127.0.0.1:8000";

const uploadBtn = document.getElementById("uploadBtn");
const loadInsightsBtn = document.getElementById("loadInsightsBtn");
const fileInput = document.getElementById("fileInput");
const uploadStatus = document.getElementById("uploadStatus");
const insightsContainer = document.getElementById("insightsContainer");

uploadBtn.addEventListener("click", async () => {
  const file = fileInput.files[0];

  if (!file) {
    uploadStatus.textContent = "Please select a file first.";
    return;
  }

  const formData = new FormData();
  formData.append("file", file);

  try {
    uploadStatus.textContent = "Uploading...";

    const response = await fetch(`${API_BASE_URL}/upload`, {
      method: "POST",
      body: formData,
    });

    const data = await response.json();

    if (!response.ok) {
      throw new Error(data.error || "Upload failed.");
    }

    uploadStatus.textContent = data.message;
  } catch (error) {
    uploadStatus.textContent = `Error: ${error.message}`;
  }
});

loadInsightsBtn.addEventListener("click", async () => {
  try {
    insightsContainer.innerHTML = "<p>Loading insights...</p>";

    const response = await fetch(`${API_BASE_URL}/insights`);
    const data = await response.json();

    if (!response.ok) {
      throw new Error(data.error || "Failed to load insights.");
    }

    insightsContainer.innerHTML = `
      <ul>
        <li><strong>Total Records:</strong> ${data.total_records}</li>
        <li><strong>Top Selling Item:</strong> ${data.top_selling_item}</li>
        <li><strong>Peak Sales Hour:</strong> ${data.peak_sales_hour}</li>
        <li><strong>Restock Suggestion:</strong> ${data.restock_suggestion}</li>
      </ul>
    `;
  } catch (error) {
    insightsContainer.innerHTML = `<p>Error: ${error.message}</p>`;
  }
});